# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Prisma) ---
# Use the Supabase "Transaction" pooler connection string for DATABASE_URL
# and the "Session" / direct connection string for DIRECT_URL.
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres

# --- Storage ---
SUPABASE_STORAGE_BUCKET=documents

# --- Email (Resend) ---
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="Document Tracking System <noreply@yourdomain.com>"

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_INSTITUTION_CODE=TAF

# Days a document may sit in one department's inbox before it's flagged
# overdue on the Master Ledger and Inbox.
NEXT_PUBLIC_SLA_DAYS=3
