// Document Tracking & Workflow Automation System
// Data model: departments, users, documents, multi-department routing,
// audit trail, reference number sequencing, and notifications.

generator client {
  provider = "prisma-client-js"
  output   = "./node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  REGISTRY_STAFF // uploads/registers incoming documents
  GM // General Manager — always the first stop after registration
  DEPARTMENT_USER // works within an assigned department
  DEPARTMENT_HEAD
  ADMIN // manages departments, users, and sees everything
}

enum DocumentStatus {
  PENDING // registered, not yet opened by any department
  IN_PROGRESS // opened / actively being handled by at least one department
  COMPLETED // all routes marked complete
  ARCHIVED
}

enum RouteStatus {
  PENDING // sitting in this department's inbox, not yet opened
  OPENED
  FORWARDED // forwarded onward — this hop is now historical
  COMPLETED // this hop is where the document's journey ended
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Department {
  id         String   @id @default(cuid())
  name       String   @unique
  code       String   @unique // short code used in reference numbers, e.g. "IT", "FIN"
  isGmOffice Boolean  @default(false) // exactly one department should be flagged true — the GM's office, the mandatory first stop
  createdAt  DateTime @default(now())

  users            User[]
  documentsCreated Document[]          @relation("DocumentsCreatedByDept")
  routesFrom       DocumentRoute[]     @relation("RouteFromDept")
  routesTo         DocumentRoute[]     @relation("RouteToDept")
  sequences        ReferenceSequence[]

  @@map("departments")
}

model User {
  id           String      @id @default(cuid())
  // Mirrors the Supabase Auth user id (auth.users.id) — Supabase handles
  // credential storage; this table holds app-level profile + role data.
  authId       String      @unique
  fullName     String
  email        String      @unique
  role         Role        @default(DEPARTMENT_USER)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())

  documentsRegistered Document[]      @relation("RegisteredBy")
  routesAssigned      DocumentRoute[] @relation("AssignedTo")
  routeActions        RouteAction[]
  notifications       Notification[]

  @@index([departmentId])
  @@map("users")
}

// One row per calendar year per institution (or per dept, if you want
// per-department numbering) — guarantees gapless, race-safe sequencing
// via a single atomic UPDATE ... RETURNING in the application layer.
model ReferenceSequence {
  id           String      @id @default(cuid())
  year         Int
  departmentId String? // null = institution-wide sequence
  department   Department? @relation(fields: [departmentId], references: [id])
  lastValue    Int         @default(0)

  @@unique([year, departmentId])
  @@map("reference_sequences")
}

model Document {
  id               String         @id @default(cuid())
  referenceNumber  String         @unique // e.g. TAF/IN/2026/001
  senderName       String
  senderOrg        String?
  subject          String
  receivedDate     DateTime
  scannedFilePath  String // path within Supabase Storage bucket
  fileSizeBytes    Int?
  originalFileName String?
  status           DocumentStatus @default(PENDING)

  registeredById String
  registeredBy   User       @relation("RegisteredBy", fields: [registeredById], references: [id])
  originDeptId   String
  originDept     Department @relation("DocumentsCreatedByDept", fields: [originDeptId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  routes      DocumentRoute[]
  auditEvents AuditEvent[]

  @@index([status])
  @@index([senderName])
  @@map("documents")
}

// One row per hop in the document's journey: Registry -> GM -> Dept A ->
// Dept B -> ... Exactly one route per document should be "active"
// (status PENDING or OPENED) at any time — that row is the document's
// current location. All earlier rows are historical (FORWARDED/COMPLETED).
model DocumentRoute {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sequence   Int // 1 = first hop (GM), 2 = second hop, etc.

  fromDeptId String?
  fromDept   Department? @relation("RouteFromDept", fields: [fromDeptId], references: [id])
  toDeptId   String
  toDept     Department  @relation("RouteToDept", fields: [toDeptId], references: [id])

  status         RouteStatus @default(PENDING)
  assignedUserId String?
  assignedUser   User?       @relation("AssignedTo", fields: [assignedUserId], references: [id])
  comments       String?

  receivedAt  DateTime  @default(now())
  openedAt    DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  actions       RouteAction[]
  notifications Notification[]

  @@unique([documentId, sequence])
  @@index([toDeptId, status])
  @@index([documentId])
  @@map("document_routes")
}

// Granular per-hop history — supports forwarding, comments, completion.
model RouteAction {
  id        String        @id @default(cuid())
  routeId   String
  route     DocumentRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  action    String // "OPENED" | "COMMENTED" | "FORWARDED" | "COMPLETED"
  note      String?
  createdAt DateTime      @default(now())

  @@map("route_actions")
}

// Top-level, document-wide audit trail (visible to Registry) — separate
// from per-route actions so Registry gets one clean timeline per document.
model AuditEvent {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actorName  String
  event      String // e.g. "REGISTERED", "ROUTED_TO_IT", "COMPLETED_BY_FINANCE"
  detail     String?
  createdAt  DateTime @default(now())

  @@index([documentId])
  @@map("audit_events")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  routeId   String?
  route     DocumentRoute?      @relation(fields: [routeId], references: [id])
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}
